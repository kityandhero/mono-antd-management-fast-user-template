import { statusCollection } from '../Common/data';

export function getStatusBadge(status) {
  let result = 'default';

  switch (status) {
    case statusCollection.enable: {
      result = 'processing';
      break;
    }

    case statusCollection.disable: {
      result = 'warning';
      break;
    }

    default: {
      result = 'default';
      break;
    }
  }

  return result;
}

export function handleItemStatus({ target, handleData, remoteData }) {
  const id = getValueByKey({
    data: handleData,
    key: fieldData.<%= o.key %>.name,
  });

  handleItem({
    target,
    value: id,
    compareValueHandler: (o) => {
      const { id: v } = o;

      return v;
    },
    handler: (d) => {
      const o = d;

      o[fieldData.status.name] = getValueByKey({
        data: remoteData,
        key: fieldData.status.name,
      });

      return d;
    },
  });
}
